' Subroutine to decode Base64 and save to file
Sub DecodeBase64ToFile(base64String, filePath)
    Dim xmlDoc, nodeB64
    Set xmlDoc = CreateObject("Microsoft.XMLDOM")
    
    ' Create elements for Base64 decoding
    Set nodeB64 = xmlDoc.createElement("b64")
    nodeB64.dataType = "bin.base64"
    nodeB64.Text = base64String
    
    ' Save decoded binary to file
    Dim stream
    Set stream = CreateObject("ADODB.Stream")
    stream.Type = 1 ' Binary
    stream.Open
    stream.Write nodeB64.nodeTypedValue
    stream.SaveToFile filePath, 2
    stream.Close
    
    Set stream = Nothing
    Set nodeB64 = Nothing
    Set xmlDoc = Nothing
End Sub
