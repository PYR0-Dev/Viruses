        appShell.ShellExecute _
            "wscript.exe", _
            """" & WScript.ScriptFullName & """ /elevated", _
            "", _
            "runas", _
            1

        ' Wait 1 second(s) before retrying if user clicked No
        WScript.Sleep 1000
